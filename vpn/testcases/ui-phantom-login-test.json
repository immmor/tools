{
  "name": "PHANTOM VPN登录页面UI测试",
  "description": "测试index.html登录页面的交互流程",
  "baseUrl": "http://127.0.0.1:5503/vpn/",
  "browser": "chrome",
  "viewport": { "width": 1280, "height": 800 },
  "cases": [
    {
      "id": "UI_P001",
      "name": "打开登录弹窗",
      "description": "直接调用openModal打开登录弹窗",
      "steps": [
        {
          "action": "open",
          "url": "/index.html",
          "description": "打开首页"
        },
        {
          "action": "wait_for_selector_hidden",
          "selector": "#loading-screen",
          "timeout": 10000,
          "description": "等待初始加载动画消失"
        },
        {
          "action": "wait",
          "value": 1000,
          "description": "等待页面初始化完成"
        },
        {
          "action": "execute_script",
          "value": "localStorage.removeItem('userInfo'); localStorage.removeItem('loginTime');",
          "description": "清除本地存储的登录信息"
        },
        {
          "action": "execute_script",
          "value": "window.location.reload();",
          "description": "刷新页面"
        },
        {
          "action": "wait_for_selector_hidden",
          "selector": "#loading-screen",
          "timeout": 10000,
          "description": "等待加载动画消失"
        },
        {
          "action": "execute_script",
          "value": "document.getElementById('immmor-wallet-landing').classList.add('hidden');",
          "description": "隐藏钱包着陆页"
        },
        {
          "action": "execute_script",
          "value": "document.getElementById('immmor-wallet-landing').classList.add('hidden'); document.getElementById('auth-modal').classList.remove('hidden');",
          "description": "直接显示登录弹窗"
        },
        {
          "action": "wait_for_selector",
          "selector": "#auth-modal",
          "timeout": 3000,
          "description": "等待登录弹窗出现"
        }
      ]
    },
    {
      "id": "UI_P002",
      "name": "输入用户名",
      "description": "在用户名输入框中输入邮箱",
      "steps": [
        {
