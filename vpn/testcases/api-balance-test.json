{
  "name": "查询用户余额接口测试",
  "description": "测试/api/balance接口的正常查询和异常情况",
  "baseUrl": "https://api.immmor.com",
  "cases": [
    {
      "id": "TC001",
      "name": "正常查询用户余额",
      "description": "使用存在的用户名查询余额",
      "request": {
        "method": "GET",
        "url": "/api/balance",
        "params": {
          "username": "kkk"
        },
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "expected": {
        "statusCode": 200,
        "response": {
          "code": 200,
          "msg": "查询成功"
        }
      }
    },
    {
      "id": "TC002",
      "name": "查询不存在的用户",
      "description": "使用不存在的用户名查询余额，期望返回404",
      "request": {
        "method": "GET",
        "url": "/api/balance",
        "params": {
          "username": "nonexistent_user_12345"
        },
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "expected": {
        "statusCode": 404,
        "response": {
          "code": 404,
          "msg": "用户不存在"
        }
      }
    },
    {
      "id": "TC003",
      "name": "缺少username参数",
      "description": "不提供username参数，期望返回400",
      "request": {
        "method": "GET",
        "url": "/api/balance",
        "params": {},
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "expected": {
        "statusCode": 400,
        "response": {
          "code": 400,
          "msg": "缺少username参数"
        }
      }
    }
  ]
}