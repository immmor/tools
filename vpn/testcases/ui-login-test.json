{
  "name": "用户登录UI自动化测试",
  "description": "测试登录页面的UI交互流程",
  "baseUrl": "https://example.com",
  "browser": "chrome",
  "viewport": { "width": 1280, "height": 800 },
  "cases": [
    {
      "id": "UI_TC001",
      "name": "正常登录流程",
      "description": "打开登录页面，输入用户名密码，点击登录按钮",
      "steps": [
        {
          "action": "open",
          "url": "/login",
          "description": "打开登录页面"
        },
        {
          "action": "wait_for_selector",
          "selector": "#username",
          "timeout": 5000,
          "description": "等待用户名输入框出现"
        },
        {
          "action": "type",
          "selector": "#username",
          "value": "testuser",
          "description": "输入用户名"
        },
        {
          "action": "type",
          "selector": "#password",
          "value": "testpass123",
          "description": "输入密码"
        },
        {
          "action": "click",
          "selector": "#login-btn",
          "description": "点击登录按钮"
        },
        {
          "action": "wait_for_selector",
          "selector": ".welcome-message",
          "timeout": 5000,
          "description": "等待欢迎消息出现"
        },
        {
          "action": "assert_text",
          "selector": ".welcome-message",
          "expected": "欢迎回来",
          "description": "断言欢迎消息文本"
        }
      ]
    },
    {
      "id": "UI_TC002",
      "name": "空密码登录",
      "description": "测试空密码登录的错误提示",
      "steps": [
        {
          "action": "open",
          "url": "/login",
          "description": "打开登录页面"
        },
        {
          "action": "wait_for_selector",
          "selector": "#username",
          "timeout": 5000,
          "description": "等待用户名输入框出现"
        },
        {
          "action": "type",
          "selector": "#username",
          "value": "testuser",
          "description": "输入用户名"
        },
        {
          "action": "click",
          "selector": "#login-btn",
          "description": "点击登录按钮"
        },
        {
          "action": "wait_for_selector",
          "selector": ".error-message",
          "timeout": 3000,
          "description": "等待错误提示出现"
        },
        {
          "action": "assert_text",
          "selector": ".error-message",
          "expected": "密码不能为空",
          "description": "断言错误提示文本"
        }
      ]
    }
  ]
}